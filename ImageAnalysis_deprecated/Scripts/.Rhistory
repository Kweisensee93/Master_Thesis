#If the number is divisible by three, it returns “fizz”. If it’s divisible by five it returns “buzz”. If it’s divisible by three and five, it returns “fizzbuzz”. Otherwise, it returns the number
fizzbuzz <- function(n){
if (n%%3 == 0 & n%%5 == 0)
return("fizzbuzz")
else if (n%%3 == 0)
return("fizz")
else if (n%%5 == 0)
return("buzz")
else{ return(n)}
}
