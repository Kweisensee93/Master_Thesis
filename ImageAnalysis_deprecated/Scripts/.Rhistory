# Kelvin to Fahrenheit, but with error, once Kelvin is below 0, cause impossible
# x K = (x × ⁠9/5⁠ − 459.67) °F
custom_K_to_F <- function(Kelvin){
if (Kelvin < 0){
stop("No values below 0 allowed")
}
else{
Fahrenheit <- ((Kelvin * 9/5) - 459.67)
return(Fahrenheit)
}
}
