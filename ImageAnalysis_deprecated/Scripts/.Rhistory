# Now without a loop, roll dice 100 and return all throws and a count of all 6
roll100x <- function(rolls=100){
throws <- sample(1:6,rolls,replace = T)
count_6 <- sum(throws == 6)
return(list(throws = throws, count_6 = count_6))
}
#If the number is divisible by three, it returns “fizz”. If it’s divisible by five it returns “buzz”. If it’s divisible by three and five, it returns “fizzbuzz”. Otherwise, it returns the number
fizzbuzz <- function(n){
if (n%3 & n%5){
return("fizzbuzz")
}
if (n%3){
#If the number is divisible by three, it returns “fizz”. If it’s divisible by five it returns “buzz”. If it’s divisible by three and five, it returns “fizzbuzz”. Otherwise, it returns the number
fizzbuzz <- function(n){
if (n%3 & n%5)
return("fizzbuzz")
if (n%3)
#If the number is divisible by three, it returns “fizz”. If it’s divisible by five it returns “buzz”. If it’s divisible by three and five, it returns “fizzbuzz”. Otherwise, it returns the number
fizzbuzz <- function(n){
if (n%%3 & n%%5)
return("fizzbuzz")
else if (n%%3)
return("fizz")
else if (n%%5)
return("buzz")
else{ return(n)}
}
