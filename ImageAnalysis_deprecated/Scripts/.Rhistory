# Roll a dice 100 times and return all throws, and a count of all 6 #use a loop
roll_100x_loop <- function(rolls=100){
throws <- numeric(rolls)
for (i in 1:rolls){
throws[[i]] <- sample(1:6,1,replace = T)
}
count_6 <- sum(throws == 6)
return(list(throws = throws, count_6 = 6))
}
